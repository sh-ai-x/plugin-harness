{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Skill Frontmatter (vendored, off-line)",
  "description": "YAML frontmatter contract for files at .claude/skills/<name>/SKILL.md.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
      "minLength": 1,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    }
  }
}
