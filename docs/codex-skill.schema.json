{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Skill Frontmatter (vendored, off-line)",
  "description": "YAML frontmatter contract for files at .codex/skills/<name>/SKILL.md. The optional `metadata` block carries OpenAI-specific fields.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
      "minLength": 1,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "metadata": {
      "type": "object",
      "description": "Optional OpenAI metadata block.",
      "properties": {
        "openai": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  }
}
