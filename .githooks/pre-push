#!/usr/bin/env bash
# .githooks/pre-push — Block direct push to main (enforce PR-only workflow)
# + auto-bump the plugin version on feature-branch pushes.
#
# Why (branch block): this repo's policy requires PR review before merge to
# main. Direct push to main bypasses review → automatic blocker.
#
# Why (version bump here, not pre-commit): pre-commit fires on every commit
# (incl. amend / rebase); bumping there would generate noise. Pre-push fires
# once per push and can compare against origin/main, making it the right
# trigger point for a release-gated decision. Mirrors dev-harness-kit's
# .githooks/pre-push convention.
#
# Version-bump decision (feature branches only, never main):
#   LOCAL version >  MAIN version → already bumped manually; skip.
#   LOCAL version == MAIN version → auto-bump PATCH, commit, then push.
#   LOCAL version <  MAIN version → refuse push; rebase onto main first.
#
# Activation:
#   git config core.hooksPath .githooks       # local-only
#
# Bypass (for maintainers ONLY with explicit —no-verify, NEVER default):
#   git push --no-verify
#
# Note: GitHub private repos without Pro cannot enforce this server-side.
# This hook is the client-side enforcement + CI will additionally gate.

set -eo pipefail

PLUGIN_JSON=".claude-plugin/plugin.json"
CODEX_PLUGIN_JSON=".codex-plugin/plugin.json"

version_of() {
    # $1 = git ref (e.g. HEAD, origin/main). Reads plugin.json's version
    # field at that ref via `git show`. Requires python3 (already a hard
    # dependency of this project).
    git show "$1:$PLUGIN_JSON" 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin)['version'])" 2>/dev/null
}

# Strict semver validator: digits.dots only. Used to guard every value
# that's about to be interpolated into a `python3 -c` shell string.
# Even though `git show` is invoked on a known-good ref, a poisoned
# ref (e.g. via environment manipulation) or a maliciously-rewritten
# plugin.json would otherwise give an attacker control of the shell
# template. Defense-in-depth: validate at every sink.
is_semver() {
    echo "$1" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'
}

semver_gt() {
    # $1 > $2 ? exit 0 : exit 1  (simple MAJOR.MINOR.PATCH integer compare)
    if ! is_semver "$1" || ! is_semver "$2"; then
        echo "[pre-push] BLOCKED: malformed semver (got '$1' vs '$2')." >&2
        exit 1
    fi
    python3 -c "
import sys
a = tuple(int(x) for x in '$1'.split('.'))
b = tuple(int(x) for x in '$2'.split('.'))
sys.exit(0 if a > b else 1)
"
}

bump_patch() {
    # $1 = current version string "X.Y.Z" -> prints "X.Y.(Z+1)"
    if ! is_semver "$1"; then
        echo "[pre-push] BLOCKED: cannot bump non-semver '$1'." >&2
        exit 1
    fi
    python3 -c "
major, minor, patch = '$1'.split('.')
print(f'{major}.{minor}.{int(patch)+1}')
"
}

# Read push lines: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    REMOTE_BRANCH="${REMOTE_REF#refs/heads/}"

    case "$REMOTE_BRANCH" in
        main|master)
            echo "[pre-push] BLOCKED: direct push to '$REMOTE_BRANCH' is disabled." >&2
            echo "" >&2
            echo "  Policy: this repo requires PR review before merge." >&2
            echo "" >&2
            echo "  Workflow:" >&2
            echo "    1. git checkout -b feat/<short-name>" >&2
            echo "    2. git push -u origin feat/<short-name>" >&2
            echo "    3. gh pr create --base main --head feat/<short-name>" >&2
            echo "    4. Wait for CI ✓ + (if reviewer assigned) approval" >&2
            echo "    5. Merge via 'gh pr merge' or GitHub UI button" >&2
            echo "" >&2
            echo "  Bypass (ONLY for emergency hotfix with explicit consent):" >&2
            echo "    git push --no-verify" >&2
            exit 1
            ;;
        *)
            # Feature branch: consider an auto-bump if plugin.json exists
            # both locally and on origin/main (skip silently otherwise —
            # e.g. very first commit before the manifest exists).
            if [ ! -f "$PLUGIN_JSON" ]; then
                continue
            fi
            if ! git rev-parse --verify -q origin/main >/dev/null; then
                # No local knowledge of origin/main yet (e.g. shallow clone
                # or first fetch not done). Skip the bump rather than fail
                # the push over a comparison we cannot make safely.
                continue
            fi

            LOCAL_VERSION="$(version_of HEAD || true)"
            MAIN_VERSION="$(version_of origin/main || true)"

            if [ -z "$LOCAL_VERSION" ] || [ -z "$MAIN_VERSION" ]; then
                # Could not read one of the two versions (e.g. main predates
                # this manifest). Skip the bump; do not block the push.
                continue
            fi

            if [ "$LOCAL_VERSION" = "$MAIN_VERSION" ]; then
                NEW_VERSION="$(bump_patch "$MAIN_VERSION")"
                # Defense-in-depth (also guarded by bump_patch above): the
                # NEW version string still goes into a shell-interpolated
                # python3 -c below. Re-validate so a future refactor of
                # bump_patch can't regress this sink.
                if ! is_semver "$NEW_VERSION"; then
                    echo "[pre-push] BLOCKED: NEW_VERSION '$NEW_VERSION' failed semver guard." >&2
                    exit 1
                fi
                echo "[pre-push] auto-bumping version: $MAIN_VERSION -> $NEW_VERSION" >&2

                python3 -c "
import json
for p in ['$PLUGIN_JSON', '$CODEX_PLUGIN_JSON']:
    try:
        data = json.load(open(p))
    except FileNotFoundError:
        continue
    data['version'] = '$NEW_VERSION'
    with open(p, 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')
"
                git add "$PLUGIN_JSON"
                [ -f "$CODEX_PLUGIN_JSON" ] && git add "$CODEX_PLUGIN_JSON"
                git commit --no-verify -m "chore(release): bump plugin-harness to v${NEW_VERSION}"
                # Find the bumped ref. We need a ref that uniquely
                # identifies the bumped commit for the in-flight push.
                # Use the local branch name (LOCAL_REF like
                # refs/heads/feat/foo) so we can pass it explicitly to
                # `git push <remote> <refspec>` — that pushes the
                # current tip of LOCAL_REF (which now includes the
                # bump commit). Reading the env var matches what Git
                # passes to the hook. Falls back to `HEAD` (which Git
                # also uses for the push) if LOCAL_REF is unset.
                if [ -n "$LOCAL_REF" ]; then
                    PUSH_BRANCH="${LOCAL_REF#refs/heads/}"
                else
                    PUSH_BRANCH="HEAD"
                fi
                # Per-pre-push-hook semantics, Git runs the hook BEFORE
                # accepting the push, so the local commits (including
                # the just-created bump) are present on the local
                # tracking ref. The push itself happens after the hook
                # returns 0. This block intentionally does not invoke
                # `git push` itself — we don't push from inside the hook
                # (avoids nested-lock + double-hook), we just amend the
                # local ref so the user's subsequent `git push` picks
                # up the bump automatically. If a downstream tool
                # (e.g. gh workflow) was going to push from CI rather
                # than the user, this hook wouldn't have fired.
            elif semver_gt "$MAIN_VERSION" "$LOCAL_VERSION"; then
                echo "[pre-push] BLOCKED: local version ($LOCAL_VERSION) is behind main ($MAIN_VERSION)." >&2
                echo "  Rebase onto origin/main first: git fetch origin main && git rebase origin/main" >&2
                exit 1
            fi
            # else: LOCAL_VERSION > MAIN_VERSION — already bumped manually, skip.
            ;;
    esac
done

exit 0
